sys:
    #  系统名称(title) 配置
    name: 知识库问答
    #  是否启用认证， true， 登录后才能使用系统;false 无需登录
    auth: true
    #  自定义数据库配置时的权限认证 token
    cfg_tkn: foobar
    # 配置可访问的域， 防止跨域攻击
    allowed_origin: http://192,168.1.122
    # 对配置信息进行加密的密钥，长度必须为16/32
    cypher_key: abaababaabaababa
api:

    # 认证服务 API
    auth_api: http://127.0.0.1:19011
    # 数据统计服务 API
    stats_api: http://127.0.0.1:19012
    # 大语言模型 API 基地址
    llm_api_uri: https://api.deepseek.com/v1
    #  大语言模型 API key
    llm_api_key: 45678
    #  大语言模型 模型名称
    llm_model_name: deepseek-v4-flash


    # embedding API 基地址
    embedding_api_uri: https://api.your_audio_service_provider.com/v1/
    # embedding API Key
    embedding_api_key: sk-xxxx
    # embedding model name
    embedding_model_name: bce-base

    # 是否为远程模式，true 表示使用远程模式，false 表示使用本地模式 ollama 接口
    is_remote: true

#  与大模型相关的提示词配置
prompts:

    # 基于知识库进行问答
    vdb_chat_msg: |
        你是一个文件知识库问答助手，请根据以下上下文信息回答问题：

        参考知识库内容：
        
        {context}
        
        历史对话：
         
         {history}
                
        以及用户提的问题：
        
        {question}
        
        请遵循以下规则：
        1. 如果{context}中没有相关信息，请明确告知用户"未在公文中找到相关内容"
        2. 回答要基于{context}中的内容，不要编造信息
        3. 引用具体公文内容时要保持原意
        4. 回答要简洁、专业