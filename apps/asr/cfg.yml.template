sys:
    #  系统名称(title) 配置
    name: 巴拉巴拉小魔仙
    #  是否启用认证， true， 登录后才能使用系统;false 无需登录
    auth: true
    #  自定义数据库配置时的权限认证 token
    cfg_tkn: foobar
    # 配置可访问的域， 防止跨域攻击
    allowed_origin: http://192,168.1.122
    # 对配置信息进行加密的密钥，长度必须为16/32
    cypher_key: abaababa
api:

    # 认证服务 API
    auth_api: http://127.0.0.1:19011
    # 数据统计服务 API
    stats_api: http://127.0.0.1:19012

    asr_http_api_uri: http://127.0.0.1:19010
    asr_ws_api_uri: ws://127.0.0.1:19010
    asr_api_key: sk-whatever
    asr_model_name: funasr

funasr:
    host: 127.0.0.1
    port: 10095
    http_api_uri: http://127.0.0.1:10095
    ws_api_uri: ws://127.0.0.1:10095